{
  "name": "rn-fabric-shimmer-example",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild:ios": "expo prebuild -p ios --clean",
    "prebuild:android": "expo prebuild -p android --clean",
    "ios:release": "expo run:ios --configuration Release",
    "android:release": "expo run:android --variant release",
    "ios:build": "xcodebuild -workspace ios/rn-fabric-shimmer-example.xcworkspace -scheme rn-fabric-shimmer-example -configuration Release -sdk iphonesimulator -derivedDataPath ios/build CODE_SIGNING_ALLOWED=NO build",
    "android:build": "cd android && ./gradlew assembleRelease",
    "typecheck": "tsc --noEmit",
    "test": "echo \"(no example-level tests)\" && exit 0"
  },
  "dependencies": {
    "@expo/log-box": "~55.0.11",
    "@expo/metro-runtime": "~55.0.11",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.96.0",
    "expo": "~55.0.24",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-image": "~55.0.10",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-fabric-shimmer": "workspace:*",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-unistyles": "^3.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "^19.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "react-native-worklets": "0.7.4",
    "typescript": "^5.8.0"
  }
}
