{
  "name": "react-native-fabric-shimmer",
  "version": "1.0.0-alpha.0",
  "description": "Dynamic shimmer skeletons for React Native — wraps the real component, measures at runtime via Fabric JSI, paints shimmer at exact positions.",
  "keywords": [
    "fabric",
    "loading",
    "react-native",
    "reanimated",
    "shimmer",
    "skeleton"
  ],
  "homepage": "https://github.com/tychota/react-native-fabric-shimmer#readme",
  "bugs": "https://github.com/tychota/react-native-fabric-shimmer/issues",
  "license": "MIT",
  "author": "Tycho Tatitscheff <tycho.tatitscheff@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tychota/react-native-fabric-shimmer.git",
    "directory": "packages/react-native-fabric-shimmer"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "package:check": "node ../../scripts/check-package.mjs .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:component": "vitest run __tests__/component",
    "test:watch": "vitest",
    "test:perf": "reassure --testMatch '**/*.perf.{ts,tsx}'",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/react-native-web-vite": "^10.3.6",
    "@swc/jest": "^0.2.39",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "chromatic": "^16.10.0",
    "expo-linear-gradient": "~55.0.14",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.83.6",
    "react-native-reanimated": "^4.2.1",
    "react-native-web": "^0.21.2",
    "reassure": "^1.4.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.6",
    "tsdown": "^0.21.10",
    "typescript": "^5.8.0",
    "vite": "^8.0.12",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "expo-linear-gradient": ">=15.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.76.0",
    "react-native-reanimated": ">=4.0.0"
  }
}
